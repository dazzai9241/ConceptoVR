      objectReference: {fileID: 0}
    - target: {fileID: 2423970045907289593, guid: a6e720393d4c116469011282c09fe3a4, type: 3}
      propertyPath: code
      value: "// Takes in a string key and returns an index in the range 0 to boxesCount
        - 1\r\n// to be used to lookup on the hashtable\r\npublic static int Hash(string
        key, int boxesCount)\r\n{\r\n    int hash = 0;\r\n\r\n    // Add all the
        character's ascii values \r\n    foreach (char c in key)\r\n    {\r\n       
        hash += c; // add ASCII value\r\n    }\r\n\r\n    // Divide the resulting
        sum by the amount of boxes and get the remainder\r\n    // The remainder
        will serve as the index for our boxes\r\n    return Mathf.Abs(hash) % boxesCount;\r\n}"
      objectReference: {fileID: 0}
    - target: {fileID: 2713593207247506858, guid: a6e720393d4c116469011282c09fe3a4, type: 3}
      propertyPath: m_PresetInfoIsWorld
      value: 1
      objectReference: {fileID: 0}
    - target: {fileID: 4106129285770532639, guid: a6e720393d4c116469011282c09fe3a4, type: 3}
      propertyPath: m_Name
      value: TemplateScriptDisplay
      objectReference: {fileID: 0}
    - target: {fileID: 5713243162175387829, guid: a6e720393d4c116469011282c09fe3a4, type: 3}
      propertyPath: m_text
      value: "<color=#6A9955>// Takes in a <color=#569CD6>string</color> key and
        returns an index in the range <color=#B5CEA8>0</color> to boxesCount - <color=#B5CEA8>1</color>\r</color>\n<color=#6A9955>//
        to be used to lookup on the hashtable\r</color>\n<color=#569CD6>public</color>
        <color=#569CD6>static</color> <color=#569CD6>int</color> <color=#DCDCAA>Hash</color>(<color=#569CD6>string</color>
        key, <color=#569CD6>int</color> boxesCount)\r\n{\r\n    <color=#569CD6>int</color>
        hash = <color=#B5CEA8>0</color>;\r\n\r\n    <color=#6A9955>// Add all the
        character's ascii values \r</color>\n    <color=#DCDCAA>foreach </color>(char
        c in key)\r\n    {\r\n        hash += c; <color=#6A9955>// add ASCII value\r</color>\n   
        }\r\n\r\n    <color=#6A9955>// Divide the resulting sum by the amount of
        boxes and get the remainder\r</color>\n    <color=#6A9955>// The remainder
        will serve as the index <color=#569CD6>for</color> our boxes\r</color>\n   
        <color=#569CD6>return</color> Mathf.<color=#DCDCAA>Abs</color>(hash) % boxesCount;\r\n}"
      objectReference: {fileID: 0}
